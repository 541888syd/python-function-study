{
  "name": "english-study",
  "version": "1.0.0",
  "private": true,
  "description": "Personal English learning and practice tool",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.20.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.1",
    "nexe": "^5.0.0-beta.4"
  }
}
